# Copy to .env and fill in. NEVER commit .env, never expose these in the frontend.

PORT=8080
CORS_ORIGIN=*                         # in prod set to your frontend origin, e.g. https://sitecut.example
CACHE_DIR=./.cache
CACHE_TTL_HOURS=168                   # 7 days

# --- keys (leave blank to disable that adapter; the router falls back to live sources) ---
ARCGIS_API_KEY=
VWORLD_KEY=
VWORLD_DOMAIN=                        # the exact domain registered with VWorld, e.g. https://sitecut.example
DATAFORSYNINGEN_TOKEN=

# --- Overture (public, no key) ---
OVERTURE_RELEASE=2025-01-22.0

# --- Copernicus CDS (ERA5-Land / CMIP6 ssp245) ---
# Requires ~/.cdsapirc AND python3 with cdsapi+xarray installed (see README). Set to 1 to enable.
ENABLE_CDS=0

# --- external tools (auto-detected; set to 0 to force-disable) ---
ENABLE_DUCKDB=1                       # Overture buildings/trees
ENABLE_GDAL=1                         # national DTM COGs
